---
// emergence-ui/components/RunCard.astro
import type { Run } from '../data/types';
import { formatDuration } from '../utils/format';
import { runBadgeClass, runBadgeText } from '../utils/library';

interface Props {
  run: Run;
  basePath: string;  // e.g. "/project-emergence" or "/emergence"
}

const { run, basePath } = Astro.props;
const href = `${basePath}/run/${run.run_number}/`;
// EMU-5 T2 + EMU-14: badge text + class derive from shared helpers in
// utils/library so RunCard + RunDetail cannot drift.  runBadgeClass is
// three-way (paused / ended / running) matching runBadgeText.  Card-level
// paused styling (BL-228) stays on the raw status field since it is
// orthogonal to the badge.
const badgeText = runBadgeText(run);
const badgeClass = runBadgeClass(run);
// BL-228: paused runs get a complementary card treatment beside the badge.
const cardClass = run.status === 'paused' ? 'em-card em-card--paused' : 'em-card';
---
<a href={href} class={cardClass} style="display: block; text-decoration: none; color: inherit; margin-bottom: 12px;">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <div class="em-h3">{run.name}</div>
      <div class="em-mono" style="margin-top: 4px;">
        {run.id.slice(0, 8)} &middot; {run.tick_count} ticks &middot; {run.sim_days.toFixed(1)} days &middot; {run.agent_count} agents &middot; Seed {run.prng_seed}
      </div>
    </div>
    <div class={badgeClass}>{badgeText}</div>
  </div>
  {run.summary && <div class="em-subtitle" style="margin-top: 8px;">{run.summary}</div>}
</a>
